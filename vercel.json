{
  "version": 2,
  "builds": [
    {
      "src": "*.php",
      "use": "vercel-php@0.7.2"
    }
  ],
  "routes": [
    { "src": "/cart", "dest": "cart.php" },
    { "src": "/address", "dest": "address.php" },
    { "src": "/payment", "dest": "payment.php" },
    { "src": "/place_order", "dest": "place_order.php" },
    { "src": "/singlepageview", "dest": "singlepageview.php" },
    { "src": "/category_products", "dest": "category_products.php" },
    { "src": "/thank-you", "dest": "thank-you.php" },
    { "src": "/(.*)", "dest": "index.php" }
  ]
}
